rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Cloud saves: users can only read/write their own save
    match /saves/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard: anyone can read, only authenticated users can write their own entry
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName', 'highestEra', 'totalKnowledge', 'totalClicks',
          'totalPrestiges', 'achievementCount', 'updatedAt'
        ])
        && request.resource.data.highestEra is int
        && request.resource.data.totalKnowledge is number;
    }
  }
}

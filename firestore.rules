rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Cloud saves: keyed by sanitized email from Cloudflare Access
    // Auth is handled at the Cloudflare edge — all requests reaching
    // the app are from authenticated users
    match /saves/{docId} {
      allow read, write: if true;
    }

    // Leaderboard: anyone can read, authenticated users can write
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
